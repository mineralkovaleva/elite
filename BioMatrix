import requests
import smtplib
from email.mime.text import MIMEText
from flask import Flask, request, jsonify
from flask_cors import CORS

app = Flask(__name__)
CORS(app)  # Разрешаем запросы от нашего HTML-сайта

# === КОНФИГУРАЦИЯ БОТА И ПОЧТЫ (Укажи свои данные) ===
MY_TOKEN = "ТВОЙ_ТОКЕН_БОТА"
MY_CHAT_ID = "ТВОЙ_ЧАТ_ID"

EMAIL_SENDER = "your_system_email@mail.ru"     # С какой почты отправлять
EMAIL_PASSWORD = "your_app_password"          # Пароль приложения из настроек почты
EMAIL_RECEIVER = "your_admin_email@gmail.com"  # На какую почту дублировать при сбое

# === ПОСЛЕДОВАТЕЛЬНОСТЬ ИЗ КАСКАДНЫХ БЛОКОВ ===

# Блок 1: Основная функция Telegram-бота
def send_to_telegram_bot(client_name, client_phone, order_details, tg_token, tg_chat_id):
    tg_url = f"https://api.telegram.org/bot{tg_token}/sendMessage"
    try:
        response = requests.post(tg_url, json={"chat_id": tg_chat_id, "text": order_details})
        if response.status_code == 200:
            print("[УСПЕХ] Заявка успешно отправлена в Telegram-бот.")
            return True
        else:
            print(f"[ОШИБКА БОТА] Код ответа от TG: {response.status_code}")
            return False
    except Exception as e:
        print(f"[КРИТИЧЕСКАЯ ОШИБКА ТГ] Не удалось связаться с сервером Telegram: {e}")
        return False

# Блок 2: Резервная функция Email-страховки
def send_backup_email(client_name, order_details):
    message_text = f"⚠️ ВНИМАНИЕ: Сбой Telegram-бота! Заявка продублирована на почту.\n\n{order_details}"
    msg = MIMEText(message_text, 'plain', 'utf-8')
    msg['Subject'] = f"🚨 РЕЗЕРВ: Заявка от {client_name}"
    msg['From'] = EMAIL_SENDER
    msg['To'] = EMAIL_RECEIVER
    
    try:
        with smtplib.SMTP_SSL('smtp.mail.ru', 465) as server:
            server.login(EMAIL_SENDER, EMAIL_PASSWORD)
            server.sendmail(EMAIL_SENDER, [EMAIL_RECEIVER], msg.as_string())
        print("[РЕЗЕРВ СРАБОТАЛ] Письмо на Email успешно отправлено.")
        return True
    except Exception as e:
        print(f"[ПОЛНЫЙ СБОЙ] Не удалось отправить даже резервное письмо: {e}")
        return False

# Блок 3: Обработчик запроса с сайта (Логика вызова)
@app.route('/api/order', methods=['POST'])
def handle_order():
    data = request.json
    name = data.get('name')
    details = data.get('details')

    # 1. Сначала пытаемся отправить через Бот (Блок 1)
    success = send_to_telegram_bot(name, None, details, MY_TOKEN, MY_CHAT_ID)

    # 2. Если функция вернула False -> включается страховка (Блок 2)
    if not success:
        send_backup_email(name, details)
        return jsonify({"status": "backup_used", "message": "Telegram не ответил, отправлено на Email"}), 200

    return jsonify({"status": "success", "message": "Успешно отправлено в Telegram"}), 200
