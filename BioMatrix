                })
            })
            .then(response => response.json())
            .then(data => {
                console.log('Server response:', data);
            })
            .catch(error => {
                console.error('Error sending to server:', error);
            });
        }

        // HUD Clock
        setInterval(() => {
            const d = new Date();
            document.getElementById('hud-clock').innerText = d.toTimeString().split(' ')[0];
        }, 1000);
