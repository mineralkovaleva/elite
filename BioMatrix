    <script>
        // 1. ДЫШАЩИЙ ФОН
        const bgCanvas = document.getElementById('bg-canvas');
        const bgCtx = bgCanvas.getContext('2d');
        let w, h;
        function resize() { w = bgCanvas.width = window.innerWidth; h = bgCanvas.height = window.innerHeight; }
        window.addEventListener('resize', resize); resize();

        const smoke = Array.from({length: 5}, () => ({
            x: Math.random() * w, y: Math.random() * h, r: Math.random() * 400 + 200, a: Math.random() * 6
        }));

        function drawBg() {
            bgCtx.fillStyle = '#030307'; bgCtx.fillRect(0,0,w,h);
            smoke.forEach(s => {
                s.a += 0.002;
                let grad = bgCtx.createRadialGradient(s.x + Math.sin(s.a)*50, s.y, 0, s.x, s.y, s.r);
                grad.addColorStop(0, `rgba(30, 15, 60, 0.05)`);
                grad.addColorStop(1, 'transparent');
                bgCtx.fillStyle = grad; bgCtx.beginPath(); bgCtx.arc(s.x, s.y, s.r, 0, 7); bgCtx.fill();
            });
            requestAnimationFrame(drawBg);
        }
        drawBg();

        // 2. DNA ДВИЖОК (Silver & Gold Edition)
        const dnaCanvas = document.getElementById('dna-canvas');
        const dnaCtx = dnaCanvas.getContext('2d');
        let dnaW, dnaH;
        function resizeDna() { dnaW = dnaCanvas.width = dnaCanvas.offsetWidth; dnaH = dnaCanvas.height = dnaCanvas.offsetHeight; }
        window.addEventListener('resize', resizeDna); resizeDna();

        let angle = 0;
        function drawDna() {
            dnaCtx.clearRect(0, 0, dnaW, dnaH);
            const cx = dnaW / 2; const nodes = 28;
            for(let i=0; i<nodes; i++) {
                let y = 60 + i * (dnaH - 120) / nodes;
                let off = Math.sin(angle + i * 0.35) * (dnaW * 0.25);
                let z = Math.cos(angle + i * 0.35);
                
                // Connection line
                dnaCtx.strokeStyle = `rgba(255,255,255, ${0.05 * (z+1)})`;
                dnaCtx.beginPath(); dnaCtx.moveTo(cx + off, y); dnaCtx.lineTo(cx - off, y); dnaCtx.stroke();

                // Helix Nodes
                dnaCtx.fillStyle = z > 0 ? "#fff" : "#333";
                dnaCtx.beginPath(); dnaCtx.arc(cx + off, y, 3 * (z+1.5)/2, 0, 7); dnaCtx.fill();
                
                dnaCtx.fillStyle = z < 0 ? "#d4af37" : "#665522";
                dnaCtx.beginPath(); dnaCtx.arc(cx - off, y, 3 * (-z+1.5)/2, 0, 7); dnaCtx.fill();
            }
            angle += 0.015;
            requestAnimationFrame(drawDna);
        }
        drawDna();

        // 3. ЛОГИКА ЗАКАЗА
        let selectedTier = "";
        let selectedMethod = "USDT (TRC20)";

        function selectTier(el, name) {
            document.querySelectorAll('.tier-card').forEach(c => c.classList.remove('active'));
